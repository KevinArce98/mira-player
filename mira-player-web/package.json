{
  "name": "mira-player-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node server.mjs",
    "postinstall": "node -e \"const fs=require('fs'),p='node_modules/sql.js/dist/sql-wasm.wasm';if(fs.existsSync(p)){fs.mkdirSync('public',{recursive:true});fs.copyFileSync(p,'public/sql-wasm.wasm');}\""
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.0",
    "@fontsource/montserrat": "^5.1.0",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/analytics": "^2.0.1",
    "hls.js": "^1.5.15",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.6.0",
    "sql.js": "^1.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/sql.js": "^1.4.9",
