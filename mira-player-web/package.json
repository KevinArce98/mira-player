{
  "name": "mira-player-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node server.mjs",
    "postinstall": "node -e \"const fs=require('fs'),p='node_modules/sql.js/dist/sql-wasm.wasm';if(fs.existsSync(p)){fs.mkdirSync('public',{recursive:true});fs.copyFileSync(p,'public/sql-wasm.wasm');}\""
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/montserrat": "^5.2.8",
    "@tanstack/react-query": "^5.101.2",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "sql.js": "^1.14.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.3",
