    <Rectangle id="bg" width="1280" height="720" color="0x000000FF" />
    <BusySpinner id="spinner" translation="[615, 330]" visible="true" />
    <Label id="errorLabel" text="" translation="[340, 340]" color="0xFF5555FF" visible="false" width="600" wrap="true" />
    <Group id="osd" visible="false">
      <Rectangle width="1280" height="110" color="0x000000BB" translation="[0, 0]" />
      <Label id="osdTitle" text="" translation="[50, 30]" color="0xFFFFFFFF" width="1100" font="font:LargeBoldSystemFont" />
      <Label id="osdTime" text="" translation="[1150, 75]" color="0x999999FF" />
      <Label id="liveLabel" text="EN VIVO" translation="[50, 75]" color="0xFF4444FF" font="font:SmallBoldSystemFont" visible="false" />
