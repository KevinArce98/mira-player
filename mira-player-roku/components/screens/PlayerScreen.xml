      <Rectangle id="nextPlayBtn" width="260" height="56" color="0xD4AA7DFF" translation="[360, 400]">
        <Label text="Reproducir ahora" width="260" height="56" horizAlign="center" vertAlign="center" color="0x272727FF" font="font:SmallBoldSystemFont" />
      </Rectangle>
      <Rectangle id="nextCancelBtn" width="260" height="56" color="0x2A2A2AFF" translation="[660, 400]">
        <Label text="Cancelar" width="260" height="56" horizAlign="center" vertAlign="center" color="0xFFFFFFFF" font="font:SmallBoldSystemFont" />
      </Rectangle>
    </Group>
  </children>
</component>
