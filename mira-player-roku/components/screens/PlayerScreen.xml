    <field id="credentials" type="assocarray" />
    <field id="streamUrl" type="string" value="" />
    <field id="contentTitle" type="string" value="" />
    <field id="posterUrl" type="string" value="" />
    <field id="episodeQueue" type="array" />
    <field id="episodeIndex" type="integer" value="-1" />
    <field id="navigate" type="assocarray" alwaysNotify="true" />
  </interface>
  <script type="text/brightscript" uri="pkg:/source/registry.brs" />
  <script type="text/brightscript" uri="pkg:/source/utils.brs" />
  <script type="text/brightscript" uri="pkg:/components/screens/PlayerScreen.brs" />
