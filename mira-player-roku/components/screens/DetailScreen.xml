<?xml version="1.0" encoding="utf-8" ?>
<component name="DetailScreen" extends="Group">
  <interface>
    <field id="credentials" type="assocarray" />
    <field id="contentData" type="assocarray" />
    <field id="contentType" type="string" value="movie" />
    <field id="navigate" type="assocarray" alwaysNotify="true" />
  </interface>
  <script type="text/brightscript" uri="pkg:/source/registry.brs" />
  <script type="text/brightscript" uri="pkg:/source/utils.brs" />
  <script type="text/brightscript" uri="pkg:/source/sync.brs" />
  <script type="text/brightscript" uri="pkg:/components/screens/DetailScreen.brs" />
  <children>
    <Rectangle width="1280" height="720" color="0x272727FF" />

    <!-- Poster (bordered card, like Tizen's .detail-poster) -->
    <Poster uri="pkg:/images/ui/rr_264x374_8.png" blendColor="0x3B3A37FF" translation="[48, 88]" />
    <Poster uri="pkg:/images/ui/rr_260x370_8.png" blendColor="0x323230FF" translation="[50, 90]" />
    <Poster id="poster" width="260" height="370" translation="[50, 90]" loadDisplayMode="scaleToZoom" />

    <!-- Info area -->
    <Label id="titleLabel" text="" translation="[340, 90]" width="860" font="font:LargeBoldSystemFont" color="0xF3EEE6FF" wrap="true" />
    <Label id="metaLabel" text="" translation="[340, 150]" color="0xA39C90FF" />
    <Label id="genreLabel" text="" translation="[340, 185]" color="0xD4AA7DFF" />
    <Label id="descLabel" text="" translation="[340, 230]" width="860" color="0xA39C90FF" wrap="true" maxLines="4" />
    <Label id="castLabel" text="" translation="[340, 350]" width="860" color="0xA39C90FF" wrap="true" maxLines="2" />

    <!-- Action buttons -->
    <Poster id="playBtn" uri="pkg:/images/ui/rr_220x54_8.png" blendColor="0xD4AA7DFF" translation="[340, 430]">
      <Label id="playBtnLabel" text="Reproducir" width="220" height="54" horizAlign="center" vertAlign="center" color="0x272727FF" font="font:MediumBoldSystemFont" />
    </Poster>
    <Poster id="favBtn" uri="pkg:/images/ui/rr_220x54_8.png" blendColor="0x323230FF" translation="[580, 430]">
      <Label id="favBtnLabel" text="Favorito" width="220" height="54" horizAlign="center" vertAlign="center" color="0xF3EEE6FF" font="font:MediumBoldSystemFont" />
    </Poster>

    <!-- Series episode list (bordered card) -->
    <Poster uri="pkg:/images/ui/rr_884x234_8.png" blendColor="0x3B3A37FF" translation="[338, 498]" visible="false" id="episodeBorder" />
    <Poster id="episodePanel" uri="pkg:/images/ui/rr_880x230_8.png" blendColor="0x323230FF" translation="[340, 500]" visible="false">
      <Label id="seasonLabel" text="Temporada 1" translation="[14, 10]" color="0xD4AA7DFF" font="font:SmallBoldSystemFont" />
      <LabelList
        id="episodeList"
        translation="[0, 40]"
        numRows="4"
        itemSize="[880, 44]"
        font="font:SmallSystemFont"
        color="0xA39C90FF"
        focusedColor="0x272727FF"
        focusBitmapBlendColor="0xD4AA7DFF"
        drawFocusFeedback="true"
      />
    </Poster>

    <!-- Spinner -->
    <BusySpinner id="spinner" translation="[620, 500]" visible="false" />

    <!-- Focus index: 0=play, 1=fav, 2=episodes -->
    <Label id="focusHint" text="" translation="[340, 500]" color="0x6E685EFF" />
  </children>
</component>
