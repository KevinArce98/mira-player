<?xml version="1.0" encoding="utf-8" ?>
<component name="CatalogScreen" extends="Group">
  <interface>
    <field id="credentials" type="assocarray" onChange="onCredentialsSet" />
    <field id="contentType" type="string" value="movie" />
    <field id="sectionTitle" type="string" value="Películas" />
    <field id="navigate" type="assocarray" alwaysNotify="true" />
  </interface>
  <script type="text/brightscript" uri="pkg:/source/registry.brs" />
  <script type="text/brightscript" uri="pkg:/source/utils.brs" />
  <script type="text/brightscript" uri="pkg:/components/screens/CatalogScreen.brs" />
  <children>
    <Rectangle width="1280" height="720" color="0x272727FF" />

    <!-- Header -->
    <Rectangle width="1280" height="70" color="0x323230FF" />
    <Label id="headerTitle" text="Películas" translation="[30, 20]" font="font:LargeBoldSystemFont" color="0xF3EEE6FF" />
    <Label id="sortLabel" text="" translation="[1220, 25]" color="0xD4AA7DFF" font="font:SmallSystemFont" horizAlign="right" />
    <Label text="Verde: Buscar   *: Ordenar   &#171;/&#187;: Mover categoría" translation="[700, 25]" color="0x6E685EFF" font="font:SmallSystemFont" />

    <!-- Category list (left column, like Tizen's .cat-col) -->
    <Rectangle width="1" height="650" color="0x3B3A37FF" translation="[240, 70]" />
    <LabelList
      id="categoryList"
      translation="[0, 70]"
      numRows="11"
      itemSize="[240, 52]"
      itemSpacing="[0, 4]"
      font="font:SmallSystemFont"
      color="0xA39C90FF"
      focusedColor="0x272727FF"
      focusBitmapBlendColor="0xD4AA7DFF"
      drawFocusFeedback="true"
    />

    <!-- Poster grid -->
    <PosterGrid
      id="posterGrid"
      translation="[264, 90]"
      numColumns="6"
      numRows="3"
      itemSize="[150, 218]"
      itemSpacing="[14, 16]"
      posterDisplayMode="scaleToZoom"
    />

    <!-- State label -->
    <Label id="stateLabel" text="Cargando…" color="0xA39C90FF" translation="[640, 350]" visible="true" />

    <!-- Spinner -->
    <BusySpinner id="spinner" translation="[620, 380]" visible="true" />

  </children>
</component>
