<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScreen" extends="Group">
  <interface>
    <field id="credentials" type="assocarray" onChange="onCredentialsSet" />
    <field id="navigate" type="assocarray" alwaysNotify="true" />
  </interface>
  <script type="text/brightscript" uri="pkg:/source/registry.brs" />
  <script type="text/brightscript" uri="pkg:/source/utils.brs" />
  <script type="text/brightscript" uri="pkg:/source/sync.brs" />
  <script type="text/brightscript" uri="pkg:/components/screens/HomeScreen.brs" />
  <children>
    <Rectangle width="1280" height="720" color="0x272727FF" />

    <!-- Sidebar (icon-rail style, like Tizen's .sidebar) -->
    <Rectangle width="190" height="720" color="0x323230FF" />
    <Rectangle width="1" height="720" color="0x3B3A37FF" translation="[189, 0]" />
    <Poster id="brandBadge" uri="pkg:/images/ui/rr_40x40_9.png" blendColor="0xD4AA7DFF" width="40" height="40" translation="[24, 28]" />
    <Label text="M" translation="[24, 28]" width="40" height="40" horizAlign="center" vertAlign="center" font="font:LargeBoldSystemFont" color="0x272727FF" />

    <!-- Nav list (icon + label rows via custom NavItem renderer) -->
    <MarkupList
      id="navList"
      translation="[0, 96]"
      numRows="7"
      itemSize="[190, 52]"
      itemSpacing="[0, 8]"
      itemComponentName="NavItem"
    />

    <!-- Content header -->
    <Label id="contentTitle" text="Inicio" translation="[224, 32]" font="font:LargeBoldSystemFont" color="0xF3EEE6FF" />

    <!-- Continue watching -->
    <Label id="continueLabel" text="Continuar viendo" translation="[224, 88]" font="font:SmallBoldSystemFont" color="0xF3EEE6FF" visible="false" />
    <Label text="*: Quitar" translation="[1180, 90]" font="font:SmallSystemFont" color="0x6E685EFF" visible="false" id="continueHint" />
    <PosterGrid
      id="continueGrid"
      translation="[224, 118]"
      numColumns="6"
      numRows="1"
      itemSize="[150, 218]"
      itemSpacing="[14, 16]"
      posterDisplayMode="scaleToZoom"
      visible="false"
    />

    <!-- Favorites -->
    <Label id="favLabel" text="Favoritos" translation="[224, 352]" font="font:SmallBoldSystemFont" color="0xF3EEE6FF" visible="false" />
    <PosterGrid
      id="favGrid"
      translation="[224, 382]"
      numColumns="6"
      numRows="1"
      itemSize="[150, 218]"
      itemSpacing="[14, 16]"
      posterDisplayMode="scaleToZoom"
      visible="false"
    />

    <!-- Empty / loading state -->
    <Label id="stateLabel" text="Cargando favoritos…" color="0xA39C90FF" translation="[224, 300]" visible="false" />

    <!-- Spinner -->
    <BusySpinner id="spinner" translation="[700, 350]" visible="false" />
  </children>
</component>
