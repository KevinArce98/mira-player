<?xml version="1.0" encoding="utf-8" ?>
<component name="SetupScreen" extends="Group">
  <interface>
    <field id="navigate" type="assocarray" alwaysNotify="true" />
  </interface>
  <script type="text/brightscript" uri="pkg:/source/registry.brs" />
  <script type="text/brightscript" uri="pkg:/source/utils.brs" />
  <script type="text/brightscript" uri="pkg:/components/screens/SetupScreen.brs" />
  <children>
    <Rectangle width="1280" height="720" color="0x272727FF" />

    <!-- Card panel (1px border + bg-element fill, like .setup-card) -->
    <Poster uri="pkg:/images/ui/rr_582x582_13.png" blendColor="0x3B3A37FF" translation="[349, 69]" />
    <Poster uri="pkg:/images/ui/rr_580x580_13.png" blendColor="0x323230FF" translation="[350, 70]" />

    <!-- Logo -->
    <Label text="Mira" translation="[350, 106]" width="580" horizAlign="center" font="font:LargeBoldSystemFont" color="0xD4AA7DFF" />
    <Label text="Conecta tu cuenta Xtream Codes" translation="[350, 156]" width="580" horizAlign="center" color="0xA39C90FF" />

    <!-- Server field -->
    <Label text="Servidor" translation="[390, 220]" color="0xA39C90FF" font="font:SmallSystemFont" />
    <Poster id="serverBorder" uri="pkg:/images/ui/rr_504x58_8.png" blendColor="0x3B3A37FF" translation="[388, 244]" />
