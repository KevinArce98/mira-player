    <!-- Username field -->
    <Label text="Usuario" translation="[390, 316]" color="0xA39C90FF" font="font:SmallSystemFont" />
    <Poster id="usernameBorder" uri="pkg:/images/ui/rr_504x58_8.png" blendColor="0x3B3A37FF" translation="[388, 340]" />
    <Poster uri="pkg:/images/ui/rr_500x54_8.png" blendColor="0x272727FF" translation="[390, 342]">
      <Label id="usernameLabel" text="Toca OK para editar" color="0x6E685EFF" translation="[16, 16]" />
    </Poster>

