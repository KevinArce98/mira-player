    <Poster id="connectBox" uri="pkg:/images/ui/rr_500x54_8.png" blendColor="0xD4AA7DFF" translation="[390, 522]">
      <Label text="Conectar" width="500" height="54" horizAlign="center" vertAlign="center" color="0x272727FF" font="font:MediumBoldSystemFont" />
    </Poster>

    <!-- Error -->
    <Label id="errorLabel" text="" color="0xE0857AFF" translation="[390, 590]" width="500" wrap="true" />

    <!-- Spinner -->
    <BusySpinner id="spinner" translation="[620, 590]" visible="false" />
