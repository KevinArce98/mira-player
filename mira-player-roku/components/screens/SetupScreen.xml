    <Label text="Contraseña" translation="[390, 412]" color="0xA39C90FF" font="font:SmallSystemFont" />
    <Poster id="passwordBorder" uri="pkg:/images/ui/rr_504x58_8.png" blendColor="0x3B3A37FF" translation="[388, 436]" />
