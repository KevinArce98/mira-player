<?xml version="1.0" encoding="utf-8" ?>
<component name="SetupScreen" extends="Group">
  <interface>
    <field id="navigate" type="assocarray" alwaysNotify="true" />
  </interface>
  <script type="text/brightscript" uri="pkg:/source/registry.brs" />
  <script type="text/brightscript" uri="pkg:/source/utils.brs" />
  <script type="text/brightscript" uri="pkg:/components/screens/SetupScreen.brs" />
  <children>
    <Rectangle width="1280" height="720" color="0x1A1A1AFF" />

    <!-- Logo -->
    <Label text="Mira" translation="[490, 100]" font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
    <Label text="Conecta tu cuenta Xtream Codes" translation="[390, 150]" color="0x999999FF" />

    <!-- Server field -->
    <Label text="Servidor" translation="[390, 230]" color="0xCCCCCCFF" />
    <Rectangle id="serverBox" width="500" height="54" color="0x2A2A2AFF" translation="[390, 255]">
      <Label id="serverLabel" text="Toca OK para editar" color="0x666666FF" translation="[14, 14]" />
    </Rectangle>

    <!-- Username field -->
    <Label text="Usuario" translation="[390, 330]" color="0xCCCCCCFF" />
    <Rectangle id="usernameBox" width="500" height="54" color="0x2A2A2AFF" translation="[390, 355]">
      <Label id="usernameLabel" text="Toca OK para editar" color="0x666666FF" translation="[14, 14]" />
    </Rectangle>

    <!-- Password field -->
    <Label text="Contraseña" translation="[390, 430]" color="0xCCCCCCFF" />
    <Rectangle id="passwordBox" width="500" height="54" color="0x2A2A2AFF" translation="[390, 455]">
      <Label id="passwordLabel" text="Toca OK para editar" color="0x666666FF" translation="[14, 14]" />
    </Rectangle>

    <!-- Connect button -->
    <Rectangle id="connectBox" width="500" height="54" color="0xD4AA7DFF" translation="[390, 540]">
      <Label text="Conectar" color="0x1A1A1AFF" translation="[200, 14]" font="font:MediumBoldSystemFont" />
    </Rectangle>

    <!-- Error -->
    <Label id="errorLabel" text="" color="0xFF5555FF" translation="[390, 610]" width="500" wrap="true" />

    <!-- Spinner -->
    <BusySpinner id="spinner" translation="[620, 610]" visible="false" />
  </children>
</component>
